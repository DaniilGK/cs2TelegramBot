# ── App ─────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ── PostgreSQL ───────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rushskins
DB_USER=postgres
DB_PASS=postgres
DB_SSL=false

# ── Redis ────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# ── JWT ──────────────────────────────────
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_EXPIRES_IN=7d

# ── Telegram ─────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_SECRET=your_webhook_secret
TELEGRAM_PAYMENT_PROVIDER_TOKEN=your_payment_provider_token_here

# ── Steam OpenID ─────────────────────────
STEAM_API_KEY=your_steam_api_key
STEAM_RETURN_URL=http://localhost:3000/auth/steam/return
STEAM_REALM=http://localhost:3000

# ── LIS-SKINS API ────────────────────────
LIS_API_KEY=your_lis_skins_key
LIS_API_BASE=https://lis-skins.ru/api
LIS_PRICE_CACHE_TTL=300          # seconds

# ── CryptoPay (Telegram payments) ────────
CRYPTOPAY_TOKEN=your_cryptopay_token
CRYPTOPAY_WEBHOOK_SECRET=your_secret

# ── Sentry ───────────────────────────────
SENTRY_DSN=

# ── Rate limiting ────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
