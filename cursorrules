const [toast, setToast] = useState('')
const showToast = (msg: string) => { setToast(msg); setTimeout(() => setToast(''), 2000) }

{toast && (
  <div className="fixed top-4 left-1/2 -translate-x-1/2 z-50 bg-[#1A1A1A] border border-[#2A2A2A] rounded-2xl px-5 py-3 text-sm font-medium text-white shadow-2xl whitespace-nowrap">
    {toast}
  </div>
)}
```

